# Gemini API 金鑰（前端 AI 助理使用，由 Vite 注入 process.env.API_KEY）
GEMINI_API_KEY=

# 後端不需要環境變數：
# - D1 database 與 R2 bucket 透過 wrangler.jsonc 的 bindings 設定
# - Cloudflare Access 簽章驗證使用的 team domain 與 AUD 也設定在 wrangler.jsonc 的 vars：
#     CF_ACCESS_TEAM  例: acme.cloudflareaccess.com
#     CF_ACCESS_AUD   例: 從 Cloudflare Zero Trust Application 取得